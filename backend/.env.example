# Server Configuration
NODE_ENV=development
PORT=5000
LOG_LEVEL=debug

# Database Configuration (PostgreSQL)
# Replace every placeholder with your own database values.
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/YOUR_DB_NAME?schema=public"
# Direct connection URL (bypasses connection pooler for migrations)
# Required when using Neon, Supabase, or PgBouncer in production
# DIRECT_DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DIRECT_DB_HOST:5432/YOUR_DB_NAME?schema=public"

# Redis (Placeholder for future scalability)
# REDIS_URL="redis://localhost:6379"

# Authentication
JWT_SECRET=replace_with_your_own_long_random_jwt_secret
JWT_EXPIRES_IN=7d

# Client Configuration
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# External APIs
GEMINI_API_KEY=your_gemini_api_key_here
GITHUB_ACCESS_TOKEN=your_github_personal_access_token_here
